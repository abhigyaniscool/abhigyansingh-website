# Supabase project credentials (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (anon public key)

# Service role key — keep secret. Used only on the server for admin mutations.
SUPABASE_SERVICE_ROLE_KEY=eyJ... (service_role key)

# The single email address that has admin rights. Sign up with this address
# from the /login page after deploying, then you'll see /admin in the nav.
ADMIN_EMAIL=you@example.com
